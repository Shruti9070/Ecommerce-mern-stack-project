# ==============================================================================
# FakeFlipkart - Environment Variables Configuration
# ==============================================================================
# 
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control
# 
# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MongoDB Connection String
# For local MongoDB:
# MONGO_URI=mongodb://localhost:27017/ecommerce
#
# For MongoDB Atlas (Cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ecommerce
#
# Documentation: https://www.mongodb.com/docs/drivers/node/

MONGO_URI=mongodb+srv://Shrutii:Shruti12@cluster0.zuuahbi.mongodb.net/ecommerce

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================

# JWT Secret - Use a strong random string
# Generate: openssl rand -hex 32
# or use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this in production!

JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Server Port
# Default: 5000
# For production, ensure port is open on firewall

PORT=5000

# ==============================================================================
# PAYMENT GATEWAY - RAZORPAY
# ==============================================================================

# Test Mode Keys (for development/testing)
# Get from: https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=rzp_test_1DP5MMOk9V27p3
RAZORPAY_KEY_SECRET=rn3PnnIYYiHw6Y5n3VJpMnJ8

# Production Keys (do NOT use test keys in production)
# Once you're ready for production:
# 1. Get production keys from Razorpay dashboard
# 2. Update these variables
# 3. Ensure environment is set to production

# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_KEY_SECRET=your_live_secret

# ==============================================================================
# TESTING CREDENTIALS
# ==============================================================================

# Test Payment Card
# Card Number: 4111 1111 1111 1111
# Expiry: Any future date (e.g., 12/25)
# CVV: Any 3 digits (e.g., 123)

# Test UPI
# UPI ID: success@razorpay

# ==============================================================================
# OPTIONAL: FUTURE INTEGRATIONS
# ==============================================================================

# Email Service (for order notifications)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# SMS Service (for order tracking)
# SMS_API_KEY=your_twilio_api_key
# SMS_ACCOUNT_SID=your_twilio_account_sid

# Cloud Storage (for product images)
# AWS_S3_BUCKET=your_bucket_name
# AWS_S3_ACCESS_KEY=your_access_key
# AWS_S3_SECRET_KEY=your_secret_key

# ==============================================================================
# NOTES
# ==============================================================================

# 1. Never commit .env to git repository
# 2. Add .env to .gitignore
# 3. Each developer should have their own .env file
# 4. For production, use secure environment variable management:
#    - Heroku: Use Config Vars
#    - AWS: Use Secrets Manager or Parameter Store
#    - Azure: Use Key Vault
#    - GCP: Use Secret Manager
#
# 5. Rotate secrets regularly
# 6. Use strong, unique values for JWT_SECRET in production
# 7. Never share keys or secrets with team members directly
# 8. Use a password manager or secure secret sharing tool

# ==============================================================================
# ENVIRONMENT SETUP COMMANDS
# ==============================================================================

# To generate a secure JWT_SECRET:
# Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OpenSSL: openssl rand -hex 32
# Python: python -c "import secrets; print(secrets.token_hex(32))"

# To start the backend with these variables:
# npm run dev

# To start the frontend:
# npm start
